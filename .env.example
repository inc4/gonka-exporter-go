# Participant wallet address (required)
PARTICIPANT_ADDRESS=gonka1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the exporter listens on inside the container (default: 9404)
EXPORTER_PORT=9404

# Metrics collection interval in seconds (default: 30)
REFRESH_INTERVAL=30

# Node RPC endpoint (Tendermint)
NODE_RPC_URL=http://node:26657

# Node REST endpoint (Cosmos SDK)
NODE_REST_URL=http://node:1317

# Public API endpoint
API_URL=http://api:9000

# Admin API endpoint (node management)
ADMIN_API_URL=http://api:9200

# Docker network name of the Gonka node stack
GONKA_NETWORK=gonka-node_default

# Number of epochs to keep in history file
MAX_EPOCH_HISTORY=500
